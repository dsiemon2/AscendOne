# ─── Node ────────────────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# ─── Rust / Tauri build artifacts (critical — target/ can be several GB) ─────
src-tauri/target/
src-tauri/gen/

# ─── SQLite databases (safety net — personal data, never commit) ─────────────
*.db
*.db-shm
*.db-wal

# ─── Environment & secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── OS / IDE ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

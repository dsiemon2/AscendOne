{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AscendOne",
  "version": "0.1.0-beta",
  "identifier": "com.ascendone.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AscendOne",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "AscendOne",
    "shortDescription": "Your personal Law of Attraction journal",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "sql": {
      "preloadConnections": ["sqlite:ascendone.db"]
    }
  }
}
